version 23.4R2-S2.1;
interfaces {
    ge-0/0/1 {
        description "to router1 - p2p link";
        unit 0 {
            family inet {
                address 10.99.0.1/31;
            }
        }
    }
    ge-0/0/2 {
        description "to client3 - LAN segment";
        unit 0 {
            family inet {
                address 192.168.99.1/24;
            }
        }
    }
    lo0 {
        unit 0 {
            family inet {
                address 10.99.99.1/32;
            }
        }
    }
    fxp0 {
        unit 0 {
            family inet {
                address 10.0.0.15/24;
            }
            family inet6 {
                address 2001:db8::2/64;
            }
        }
    }
}
routing-instances {
    mgmt_junos {
        routing-options {
            rib mgmt_junos.inet6.0 {
                static {
                    route ::/0 next-hop 2001:db8::1;
                }
            }
            static {
                route 0.0.0.0/0 next-hop 10.0.0.2;
            }
        }
    }
}
routing-options {
    router-id 10.99.99.1;
    autonomous-system 65200;
    static {
        route 192.168.99.0/24 discard;
    }
}
policy-options {
    policy-statement export-to-fabric {
        term client3-network {
            from {
                protocol [ direct static ];
                route-filter 192.168.99.0/24 exact;
            }
            then accept;
        }
        term deny {
            then reject;
        }
    }
    policy-statement import-from-fabric {
        term accept-all {
            then accept;
        }
    }
}
protocols {
    bgp {
        group fabric {
            type external;
            family inet {
                unicast;
            }
            export export-to-fabric;
            import import-from-fabric;
            neighbor 10.99.0.0 {
                description router1;
                peer-as 65100;
            }
        }
        log-updown;
        graceful-restart;
    }
    lldp {
        port-id-subtype interface-name;
        interface all;
    }
}
