#
set system host-name juniper-vxlan-l3vni-novlan
#
set interfaces lo0 unit 0 family inet address 10.0.0.111/32 primary
set interfaces irb unit 20 family inet address 10.0.2.111/24 preferred
set routing-options autonomous-system 65001
set routing-options router-id 10.0.0.111
# set up ip-vrf
set routing-instances l3vni_vrf protocols evpn ip-prefix-routes advertise direct-nexthop
set routing-instances l3vni_vrf protocols evpn ip-prefix-routes encapsulation vxlan
set routing-instances l3vni_vrf protocols evpn ip-prefix-routes vni 50020
set routing-instances l3vni_vrf interface irb.20
set routing-instances l3vni_vrf route-distinguisher 192.168.255.1:15004
set routing-instances l3vni_vrf vrf-target export target:15004:15004
set routing-instances l3vni_vrf vrf-table-label
set protocols evpn vni-options vni 5020 vrf-target target:65000:5020
set protocols evpn encapsulation vxlan
set protocols evpn extended-vni-list all
set protocols igmp-snooping vlan default
set switch-options vtep-source-interface lo0.0
set switch-options route-distinguisher 192.168.100.111:1
set switch-options vrf-target target:65000:1
set routing-instances l3vni_vrf interface irb.20
#
