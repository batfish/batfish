!RANCID-CONTENT-TYPE: paloalto
config {
  devices {
    localhost.localdomain {
      deviceconfig {
        system {
          hostname "paloalto_layer2_ae_svi";
        }
      }
      network {
        interface {
          ethernet {
            ethernet1/1 {
              aggregate-group ae1;
            }
          }
          aggregate-ethernet {
            ae1 {
              layer2 {
                units {
                  ae1.10 {
                    tag 10;
                  }
                  ae1.20 {
                    tag 20;
                  }
                }
              }
            }
          }
          vlan {
            units {
              vlan.10 {
                ip {
                  10.0.10.1/24;
                }
              }
              vlan.20 {
                ip {
                  10.0.20.1/24;
                }
              }
            }
          }
        }
        virtual-router {
          default {
            interface [ vlan.10 vlan.20 ];
          }
        }
      }
    }
  }
}
