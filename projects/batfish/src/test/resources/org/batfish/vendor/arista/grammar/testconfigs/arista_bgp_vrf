!RANCID-CONTENT-TYPE: arista
!
hostname arista_bgp_vrf
!
router bgp 1
  bgp cluster-id 1.2.3.4
  vrf FOO
    bgp cluster-id 0.0.0.0
    bgp bestpath as-path multipath-relax
    bgp bestpath tie-break router-id
    rd 123:123
    route-target export 1:1
    route-target import 2:2
    local-as 65000
!
  vrf BAR
    no bgp bestpath as-path multipath-relax
    bgp bestpath tie-break cluster-list-length
!
  vrf MULTI
    rd 123:456
    route-target import evpn 65000:100
    route-target import evpn 65000:200
    route-target export evpn 65000:300
    route-target export evpn 65000:400

vrf instance FOO
vrf instance BAR
vrf instance MULTI
