    }
    login {
        user admin {
            uid 2000;
            class super-user;
            authentication {
                encrypted-password "$6$CiA8qBCH$QYE8nyY4hWzHDe9DTbhBTAbF/Zdk2l/I3/PCEBaZGS0Y2yylqLeYyC5pUfwWTIlWKD6Eb4VWsog14RyL1HXfS1"; ## SECRET-DATA
            }
        }
    }
    services {
        netconf {
            ssh;
