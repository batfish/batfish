## Access Switch 2 - between client2 and node1-2 (leaf2)
version 25.4R1.12;
system {
    host-name sw2;
    root-authentication {
        encrypted-password "$6$xQkmIDVo$Wq9G.CmX7jTm/J5oFGPTcQMwNhdi9pv4u8Bj4F9l98eUGKKu3sA2XsOY9aAnxzhX.Ii.GdHena3QyYB4TNvs60";
    }
    login {
        user admin {
            uid 2000;
            class super-user;
            authentication {
                encrypted-password "$6$CiA8qBCH$QYE8nyY4hWzHDe9DTbhBTAbF/Zdk2l/I3/PCEBaZGS0Y2yylqLeYyC5pUfwWTIlWKD6Eb4VWsog14RyL1HXfS1";
            }
        }
    }
    services {
        netconf {
            ssh;
        }
        ssh {
            root-login allow;
        }
    }
    management-instance;
}
chassis {
    fpc 0 {
        pic 0 {
            number-of-ports 12;
        }
    }
}
interfaces {
    ge-0/0/1 {
        description "to client2 - access port";
        unit 0 {
            family ethernet-switching {
                interface-mode access;
                vlan {
                    members VLAN200;
                }
            }
        }
    }
    ge-0/0/2 {
        description "to node1-2 (leaf2) - trunk uplink";
        unit 0 {
            family ethernet-switching {
                interface-mode trunk;
                vlan {
                    members [ VLAN200 VLAN400 ];
                }
            }
        }
    }
    fxp0 {
        unit 0 {
            family inet {
                address 10.0.0.15/24;
            }
            family inet6 {
                address 2001:db8::2/64;
            }
        }
    }
}
forwarding-options {
    storm-control-profiles default {
        all;
    }
}
routing-instances {
    mgmt_junos {
        routing-options {
            rib mgmt_junos.inet6.0 {
                static {
                    route ::/0 next-hop 2001:db8::1;
                }
            }
            static {
                route 0.0.0.0/0 next-hop 10.0.0.2;
            }
        }
    }
}
vlans {
    VLAN200 {
        vlan-id 200;
    }
    VLAN400 {
        vlan-id 400;
    }
}
protocols {
    lldp {
        port-id-subtype interface-name;
        interface all;
    }
    rstp {
        interface all;
    }
}
